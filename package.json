{
  "name": "@saroby/tts-cli",
  "version": "0.2.0",
  "description": "Actor-centric multi-provider TTS CLI",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "tts": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/cli/index.ts",
    "setup:chatterbox": "node --import tsx src/cli/index.ts setup chatterbox",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:live": "TTS_LIVE=1 vitest run test/live-smoke.test.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "node-edge-tts": "^1.2.10",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
